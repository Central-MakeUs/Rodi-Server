# 로컬 개발 DB 설정 — 이 파일을 .env 로 복사해서 사용하세요 (cp .env.example .env)
# docker compose 와 스프링 local 프로파일이 이 값을 읽습니다.

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=

# Discord 알림 웹훅 — 비우면 전송 안 함. (URL은 시크릿: 커밋 금지)
#  ERROR  = 5xx 서버 오류 채널
#  HEALTH = 서버 기동/종료(재배포) 채널
DISCORD_ERROR_WEBHOOK_URL=
DISCORD_HEALTH_WEBHOOK_URL=

# JWT 서명 시크릿 — HS256이라 최소 32바이트 필요. 로컬/운영 각각 직접 채워 넣으세요.
JWT_SECRET=

# 애플 로그인 (Sign in with Apple)
#  APPLE_CLIENT_ID = Bundle ID
#  APPLE_PRIVATE_KEY = .p8 내용을 한 줄로(-----BEGIN/END----- 및 개행 제거한 base64 본문). 시크릿.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=
APPLE_PRIVATE_KEY=

# 카카오 Admin 키 — 탈퇴 시 연결 해제(unlink)용. 시크릿.
KAKAO_ADMIN_KEY=

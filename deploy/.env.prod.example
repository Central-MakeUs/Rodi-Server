# 이 파일을 서버의 /opt/rodi/.env 로 복사해 실제 값으로 채우세요.
# .env 는 git에 커밋하지 않습니다 (.gitignore 처리됨).

# --- PostgreSQL / PostGIS ---
POSTGRES_DB=rodi
POSTGRES_USER=rodi
POSTGRES_PASSWORD=change-me-strong-password

# --- 알림 (선택, 미설정 시 Slack 전송 안 함) ---
SLACK_WEBHOOK_URL=

# --- 배포 이미지 태그 (CD가 주입. 수동 실행 시 생략하면 latest) ---
# IMAGE_TAG=latest
